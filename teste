!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Meu Teste DISC</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .pergunta { margin-bottom: 20px; }
        button { margin: 5px 0; padding: 10px; cursor: pointer; width: 100%; text-align: left; }
    </style>
</head>
<body>

    <h1>Descubra seu Perfil DISC</h1>

    <div class="pergunta">
        <p><strong>1. Quando você está em um projeto em grupo, você geralmente:</strong></p>
        <button onclick="registrarResposta('D')">A) Assume a liderança e foca em entregar logo o resultado</button>
        <button onclick="registrarResposta('I')">B) Anima a equipe e foca em manter todos engajados</button>
        <button onclick="registrarResposta('S')">C) Age como apaziguador e foca na harmonia do time</button>  
        <button onclick="registrarResposta('C')">D) Organiza as planilhas e foca nos detalhes e na precisão</button>
    </div>

    <h2 id="mensagem-resultado"></h2>

    <script>
        // Esta é a "inteligência" da nossa ferramenta
        function registrarResposta(perfilEscolhido) {
            let nomeDoPerfil = "";

            if (perfilEscolhido === 'D') {
                nomeDoPerfil = "Dominância (D)";
            } else if (perfilEscolhido === 'I') {
                nomeDoPerfil = "Influência (I)";
            } else if (perfilEscolhido === 'S') {
                nomeDoPerfil = "Estabilidade (S)";
            } else if (perfilEscolhido === 'C') {
                nomeDoPerfil = "Conformidade (C)";
            }

            // Exibe o resultado na tela
            document.getElementById('mensagem-resultado').innerText = "Com base nessa resposta, seu traço mais forte é: " + nomeDoPerfil;
        }
    </script>

</body>
</html>
